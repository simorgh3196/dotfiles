{
	"artifactReviewPolicy": "agent-decides",
	"colorScheme": "tokyo night",
	"editor": "vim",
	"enableTelemetry": false,
	"model": "Gemini 3.5 Flash (High)",
	"notifications": true,
	"permissions": {
		"allow": [
			"command(agent-browser)",
			"command(cargo)",
			"command(cat)",
			"command(cd)",
			"command(cp)",
			"command(cursor-agent)",
			"command(diff)",
			"command(echo)",
			"command(env)",
			"command(fd)",
			"command(find)",
			"command(gh)",
			"command(ghq)",
			"command(git)",
			"command(grep)",
			"command(head)",
			"command(ls)",
			"command(mise)",
			"command(mkdir)",
			"command(na)",
			"command(nci)",
			"command(nci)",
			"command(nd)",
			"command(ni)",
			"command(nlx)",
			"command(nr)",
			"command(nun)",
			"command(nup)",
			"command(ps)",
			"command(pwd)",
			"command(rg)",
			"command(sed)",
			"command(tail)",
			"command(which)"
		],
		"deny": ["command(git push)"]
	},
	"statusLine": {
		"type": "command",
		"command": "~/dotfiles/antigravity-cli/statusline.sh",
		"enabled": true
	},
	"toolPermission": "proceed-in-sandbox",
	"trustedWorkspaces": []
}
